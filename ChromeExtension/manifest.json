{
  "manifest_version": 3,
  "name": "MacroHub Bridge",
  "version": "1.1.0",
  "description": "MacroHub AI IDE Chrome bridge for Copilot-style pages.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://localhost:9876/*",
    "http://127.0.0.1:9876/*",
    "https://copilot.microsoft.com/*",
    "https://www.bing.com/*",
    "https://claude.ai/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://copilot.microsoft.com/*",
        "https://www.bing.com/*",
        "https://claude.ai/*",
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "MacroHub Bridge"
  }
}
