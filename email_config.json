      "maxAgeDays": 7
    },
    "Approvals": {
      "keywords": ["approve", "approval", "sign off", "authorization", "review and approve"],
      "senderFilter": "",
      "folderFilter": "Inbox",
      "maxAgeDays": 5
    },
    "Audit Requests": {
      "keywords": ["audit", "PBC", "provided by client", "confirmation", "audit request", "supporting documentation"],
      "senderFilter": "",
